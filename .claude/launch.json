{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Netlify Dev",
      "runtimeExecutable": "netlify",
      "runtimeArgs": ["dev", "--port", "8888"],
      "port": 8888
    },
    {
      "name": "Python static server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "npx serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "3000", "."],
      "port": 3000
    }
  ]
}
